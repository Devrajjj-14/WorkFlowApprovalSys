{
  "ConnectionStrings": {
    "DefaultConnection": "server=YOUR_PRODUCTION_SERVER;port=3306;database=workflow_approval_db;user=prod_user;password=YOUR_SECURE_PASSWORD;"
  },
  "Jwt": {
    "Key": "GENERATE_A_STRONG_256_BIT_KEY_AND_PLACE_HERE",
    "Issuer": "WorkflowApprovalApi",
    "Audience": "WorkflowApprovalApiUsers",
    "ExpiryMinutes": 120
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Error",
        "Microsoft.EntityFrameworkCore": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "/var/log/workflowapi/custom logger {Date:yyyy-MM-dd}.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Error"
    }
  },
  "ApplicationInsights": {
    "InstrumentationKey": "YOUR_PRODUCTION_INSTRUMENTATION_KEY_HERE"
  },
  "AllowedHosts": "*"
}
