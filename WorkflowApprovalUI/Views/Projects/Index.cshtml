@model List<WorkflowApprovalUI.Models.ProjectResponse>
@{ ViewData["Title"] = "Projects"; }

@section TopbarActions {
    <button class="btn-primary" onclick="openModal('modal-new-project')">
        <i class="fa-solid fa-plus"></i> New Project
    </button>
}

@if (!Model.Any())
{
    <div class="empty-state">
        <i class="fa-solid fa-folder-open"></i>
        <h3>No projects yet</h3>
        <p>Create your first project to get started.</p>
        <button class="btn-primary" onclick="openModal('modal-new-project')">
            <i class="fa-solid fa-plus"></i> New Project
        </button>
    </div>
}
else
{
    <div class="projects-grid">
        @foreach (var p in Model)
        {
            <a asp-action="Detail" asp-route-id="@p.Id" class="project-card">
                <div class="project-card-header">
                    <div class="project-icon">@p.Name[0..1].ToUpper()</div>
                    <span class="status-badge status-@p.Status.ToLower().Replace(" ","")">@p.Status</span>
                </div>
                <div class="project-card-body">
                    <h3 class="project-title">@p.Name</h3>
                    <p class="project-desc">@(p.Description.Length > 90 ? p.Description[..90] + "…" : p.Description)</p>
                </div>
                <div class="project-card-footer">
                    <span><i class="fa-regular fa-calendar"></i> @p.CreatedAt.ToString("MMM d, yyyy")</span>
                    <span class="card-arrow"><i class="fa-solid fa-arrow-right"></i></span>
                </div>
            </a>
        }
    </div>
}

<!-- New Project Modal -->
<div id="modal-new-project" class="modal-overlay" onclick="closeModalOutside(event,'modal-new-project')">
    <div class="modal">
        <div class="modal-header">
            <h3><i class="fa-solid fa-folder-plus"></i> New Project</h3>
            <button class="modal-close" onclick="closeModal('modal-new-project')"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <form method="post" asp-controller="Projects" asp-action="Create">
            <div class="modal-body">
                <div class="form-group">
                    <label>Project name</label>
                    <input name="Name" type="text" class="form-input" placeholder="e.g. Brand Refresh 2025" required />
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea name="Description" class="form-input form-textarea" placeholder="Describe the project scope…"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-ghost" onclick="closeModal('modal-new-project')">Cancel</button>
                <button type="submit" class="btn-primary">Create Project</button>
            </div>
        </form>
    </div>
</div>
